:80 {
	root * /srv
	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=(), accelerometer=(), autoplay=(), encrypted-media=(), gyroscope=(), magnetometer=(), midi=(), payment=(), usb=(), sync-xhr=()"
		X-Permitted-Cross-Domain-Policies "none"
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; media-src 'self' blob:; worker-src 'self' blob:; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'none'; require-trusted-types-for 'script'; trusted-types oscilloscope-template"
		# Note: Strict-Transport-Security, Cross-Origin-Opener-Policy, Cross-Origin-Resource-Policy
		# are emitted by the HOST Caddy proxy layer via dokku caddy:labels:add to avoid header doubling.
		-Server
	}

	# Long-cache static assets so lighthouse `uses-long-cache-ttl` passes (#853).
	@longcache path /js/*.js /styles.css /favicon.svg /og-cover.svg /icon-*.png /manifest.webmanifest
	header @longcache Cache-Control "public, max-age=2592000, must-revalidate"
	handle /health {
		header Content-Type application/json
		respond `{"status":"ok"}` 200
	}
	handle /healthz {
		header Content-Type application/json
		respond `{"status":"ok"}` 200
	}
	handle /version {
		header Content-Type application/json
		respond `{"app":"oscilloscope","version":"1.0.8","classification":"tool/public/active"}` 200
	}
	@static path_regexp static \.((jpg|jpeg|png|gif|svg|ico|css|js|woff2?|ttf|webmanifest))$
	header @static Cache-Control "public, immutable"
	handle {
		header Cache-Control "no-cache, must-revalidate"
		try_files {path} {path}/ =404
		file_server
	}
	handle_errors {
		@notfound expression {err.status_code} == 404
		rewrite @notfound /404.html
		file_server
	}
}
